#!/usr/bin/env bash
# Pre-commit hook: run the code-debt scanner before allowing any commit.
#
# CLAUDE.md Rule 15 — every TODO/FIXME/hopeful-phrase comment in source code
# MUST have a TD-XXXX registry entry in docs/code-debt-registry.md.
#
# Activated automatically by the root package.json "postinstall" script which
# sets `git config core.hooksPath .githooks` on first `npm install`.
#
# Bypass: `git commit --no-verify` — emergency only, document the
# justification in the commit message. Using --no-verify without a real
# justification is a Rule 13 violation (intellectual honesty).

set -euo pipefail

echo ""
echo "→ Pre-commit: running code-debt check (Rule 15)…"

if npm run debt:check --silent; then
  exit 0
else
  echo ""
  echo "✗ Code-debt check FAILED. Commit blocked."
  echo ""
  echo "Fix options:"
  echo "  1. \`npm run debt:add\`  — interactively register the comment as TD-XXXX"
  echo "  2. Hand-edit docs/code-debt-registry.md, then update the comment to reference TD-XXXX"
  echo "  3. \`npm run debt:check\` to re-verify"
  echo ""
  echo "Bypass (emergency only — document in commit message):"
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi
